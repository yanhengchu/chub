#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import shlex
import subprocess


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--name", required=True)
    parser.add_argument("--cwd", required=True)
    parser.add_argument("--chub-session", required=True)
    parser.add_argument("--hook-dir", required=True)
    parser.add_argument("--codex-session")
    args = parser.parse_args()

    existing = subprocess.run(
        ["tmux", "has-session", "-t", args.name],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    if existing.returncode == 0:
        os.execvp("tmux", ["tmux", "attach-session", "-t", args.name])

    codex = ["codex", "--profile", "chub"]
    if args.codex_session:
        codex.extend(["resume", args.codex_session])
    command = " ".join(
        (
            f"CHUB_PTY_SESSION_ID={shlex.quote(args.chub_session)}",
            f"CHUB_PTY_HOOK_DIR={shlex.quote(args.hook_dir)}",
            shlex.join(codex),
        )
    )
    os.execvp(
        "tmux",
        [
            "tmux",
            "new-session",
            "-s",
            args.name,
            "-c",
            args.cwd,
            command,
        ],
    )


if __name__ == "__main__":
    raise SystemExit(main())
